FROM node:latest

ARG NEXTAUTH_SECRET
ARG BACKEND_API
ARG NEXT_PUBLIC_HOST
ARG NEXTAUTH_URL
ARG API_KEY

ENV NODE_ENV="production"
ENV NEXTAUTH_SECRET $NEXTAUTH_SECRET
ENV BACKEND_API $BACKEND_API
ENV NEXT_PUBLIC_HOST $NEXT_PUBLIC_HOST
ENV NEXTAUTH_URL $NEXTAUTH_URL
ENV NEXT_PUBLIC_BACKEND_API $BACKEND_API
ENV API_KEY $API_KEY

WORKDIR /app
COPY package*.json ./

COPY . .

RUN npm install
RUN npm run build

EXPOSE 3333

CMD [ "npm", "run", "start" ]
